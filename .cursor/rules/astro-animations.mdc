# Motion One

## Setup

```js
import { animate, scroll, inView, stagger } from "motion"
```

## Core API

```js
animate(".hero", { opacity: [0, 1], y: [30, 0] }, { duration: 0.6, easing: "ease-out" })
```

## Scroll Reveal

```astro
<script>
  import { inView, animate, stagger } from "motion"

  // Elemento único
  inView(".hero-text", ({ target }) => {
    animate(target, { opacity: [0, 1], y: [30, 0] }, { duration: 0.7, easing: [0.16, 1, 0.3, 1] })
  })

  // Múltiplos com stagger
  inView(".features", () => {
    animate(".feature-card",
      { opacity: [0, 1], y: [24, 0] },
      { duration: 0.5, delay: stagger(0.1), easing: "ease-out" }
    )
  })
</script>
```

## Page Entrance

```js
animate(
  ["nav", "h1", "h1 + p", ".cta-btn"],
  { opacity: [0, 1], y: [20, 0] },
  { duration: 0.6, delay: stagger(0.15), easing: "ease-out" }
)
```

## Hover

```js
document.querySelectorAll(".card").forEach(card => {
  card.addEventListener("mouseenter", () => animate(card, { scale: 1.03, y: -4 }, { duration: 0.2 }))
  card.addEventListener("mouseleave", () => animate(card, { scale: 1, y: 0 }, { duration: 0.3 }))
})
```

## Parallax

```js
scroll(
  animate(".hero-visual", { y: [0, -80] }),
  { target: document.querySelector(".hero"), offset: ["start start", "end start"] }
)
```

## Easing Reference

| Efeito | Valor |
|---|---|
| Snappy | `[0.16, 1, 0.3, 1]` |
| Linear | `"linear"` |
| Ease out | `"ease-out"` |
| Spring | `{ type: "spring", stiffness: 300, damping: 20 }` |

