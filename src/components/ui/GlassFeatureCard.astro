---
/** Cartão `glass-card`: `with-media` (soluções com imagem) ou `compact` (grade sobre). */
interface Props {
	class?: string
	variant?: 'with-media' | 'compact'
}

const { class: className = '', variant = 'compact' } = Astro.props

const layout =
	variant === 'with-media'
		? 'group flex h-full min-h-[500px] flex-col justify-between overflow-hidden p-8'
		: 'flex flex-col gap-4 p-8'
---

<div class:list={['glass-card', layout, className]}>
	<slot />
</div>
