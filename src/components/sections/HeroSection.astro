---
import { Image } from 'astro:assets'
import heroBg from '../../assets/images/hero-bg.png'
import Button from '../ui/Button.astro'

interface Props {
	class?: string
}

const { class: className = '' } = Astro.props
---

<section
	id="home"
	class:list={[
		'relative flex min-h-screen scroll-mt-28 flex-col items-center justify-center overflow-hidden px-8 md:pt-20',
		className,
	]}
	aria-labelledby="hero-heading"
>
	<div data-hero-bg class="absolute inset-0 z-0 opacity-0">
		<Image
			src={heroBg}
			alt=""
			class="h-full w-full object-cover opacity-40 mix-blend-screen"
			width={512}
			height={512}
			loading="eager"
			fetchpriority="high"
			aria-hidden="true"
		/>
		<div class="absolute inset-0 bg-gradient-to-b from-transparent via-background/50 to-background"></div>
	</div>
	<div data-hero-stagger class="relative z-10 max-w-5xl space-y-8 text-center pb-[72px] md:pb-0">
		<p class="mb-4 flex items-center justify-center gap-3 opacity-0">
			<span class="status-orbit animate-pulse" aria-hidden="true"></span>
			<span
				class="font-label text-ols-eyebrow uppercase tracking-[var(--ols-text-eyebrow-tracking)] text-[8px] md:text-xs md:text-secondary"
			>
				Design &amp; Desenvolvimento Sob Medida
			</span>
		</p>
		<h1
			id="hero-heading"
			class="font-headline text-5xl font-bold leading-[var(--ols-text-display-line-height)] tracking-tighter text-white opacity-0 md:text-8xl"
		>
			Automatize. Integre. <br />
			<span class="metallic-text-shine">Transborde.</span>
		</h1>
		<p
			class="mx-auto max-w-2xl font-body text-xl font-light leading-relaxed text-secondary opacity-0"
			style="font-size: var(--ols-text-lead); line-height: var(--ols-text-lead-line-height)"
		>
			Ecossistemas de IA, sistemas customizados e design de alta performance. A potência da <span
				class="font-medium text-white">Automação</span
			> encontra a elegância do <span class="font-medium text-white">Desenvolvimento Sob Medida</span>.
		</p>
		<div class="opacity-0">
			<Button
				href="#contato"
				class="inline-block px-5 md:px-10 py-5 md:text-lg"
			>
				Quero escalar minha operação.
			</Button>
		</div>
	</div>
</section>

<script>
	import { domReveal, stagger } from '../../lib/animate-dom'
	import { prefersReducedMotion } from '../../lib/prefers-reduced-motion'

	function run() {
		const bg = document.querySelector('[data-hero-bg]')
		const staggerRoot = document.querySelector('[data-hero-stagger]')
		if (!staggerRoot) return

		if (prefersReducedMotion()) {
			staggerRoot.querySelectorAll(':scope > *').forEach((el) => el.classList.remove('opacity-0'))
			bg?.classList.remove('opacity-0')
			return
		}

		if (bg) {
			domReveal(bg, { opacity: [0, 1] }, { duration: 0.9 })
		}

		const kids = staggerRoot.children
		domReveal(kids, { opacity: [0, 1], y: [28, 0] }, { duration: 0.65, delay: stagger(0.1) })
	}

	run()
</script>
