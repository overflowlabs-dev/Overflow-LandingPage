---
import { getPublicEnv } from '../../../lib/env-provider.mjs'
import Button from '../../ui/Button.astro'

interface Props {
	class?: string
}

const { class: className = '' } = Astro.props
const env = getPublicEnv(import.meta.env)
const accessKey = env.PUBLIC_WEB3FORMS_ACCESS_KEY
const formSubmitEndpoint = env.PUBLIC_FORM_ENDPOINT
const nameMaxLength = 100
const phoneMaxLength = 16
const emailMaxLength = 254
const messageMaxLength = 2000

const fieldBase =
	'min-h-11 w-full border-0 border-b border-outline-variant bg-transparent px-0 py-2.5 font-body text-sm text-white placeholder:text-surface-container-highest focus:border-white focus:ring-0 focus:outline-none md:min-h-0 md:py-3 md:text-base'
const labelBase =
	'col-start-1 row-start-1 font-label uppercase tracking-[var(--ols-text-label-tracking)] text-secondary/60 text-[0.625rem] leading-tight md:text-xs md:leading-normal md:text-ols-label'
const errorBase =
	'col-start-1 row-start-3 hidden min-h-0 text-xs leading-snug text-red-300/95 transition-opacity duration-200 md:col-start-2 md:row-start-1 md:max-w-[min(100%,14rem)] md:justify-self-end md:text-right'
const gridBase =
	'grid min-w-0 grid-cols-1 gap-y-1 md:grid-cols-[minmax(0,1fr)_auto] md:gap-x-3 md:gap-y-2'
---

<form
	id="contact-form"
	class:list={['w-full min-w-0 max-w-full space-y-5 md:space-y-10', className]}
	novalidate
>
	<input type="hidden" name="access_key" value={accessKey} />
	<input type="hidden" name="form_submit_endpoint" value={formSubmitEndpoint} />
	<input type="hidden" name="subject" value="Contato — Overflow Labs" />
	<input
		type="text"
		name="_honey"
		style="display:none"
		tabindex="-1"
		autocomplete="off"
		aria-hidden="true"
	/>
	<div class="flex flex-col gap-5 md:gap-8">
		<div class:list={[gridBase]}>
			<label for="contact-name" class:list={[labelBase]}>
				Nome
			</label>
			<p id="contact-name-error" class:list={[errorBase]} role="alert" aria-live="polite"></p>
			<input
				id="contact-name"
				name="name"
				type="text"
				required
				maxlength={nameMaxLength}
				class:list={[fieldBase, 'col-span-full row-start-2 min-w-0 md:col-span-2 md:row-start-2']}
				placeholder="Como devemos te chamar?"
				autocomplete="name"
				aria-describedby="contact-name-error"
			/>
		</div>
		<div class:list={[gridBase]}>
			<label for="contact-phone" class:list={[labelBase]}>
				Telefone (WhatsApp)
			</label>
			<p id="contact-phone-error" class:list={[errorBase]} role="alert" aria-live="polite"></p>
			<input
				id="contact-phone"
				name="phone"
				type="tel"
				required
				maxlength={phoneMaxLength}
				inputmode="numeric"
				class:list={[fieldBase, 'col-span-full row-start-2 min-w-0 md:col-span-2 md:row-start-2']}
				placeholder="(41) 9 9999-9999"
				autocomplete="tel-national"
				aria-describedby="contact-phone-error"
			/>
		</div>
		<div class:list={[gridBase]}>
			<label for="contact-email" class:list={[labelBase]}>
				E-mail
			</label>
			<p id="contact-email-error" class:list={[errorBase]} role="alert" aria-live="polite"></p>
			<input
				id="contact-email"
				name="email"
				type="email"
				required
				maxlength={emailMaxLength}
				class:list={[fieldBase, 'col-span-full row-start-2 min-w-0 md:col-span-2 md:row-start-2']}
				placeholder="seu@email.com"
				autocomplete="email"
				aria-describedby="contact-email-error"
			/>
		</div>
		<div class:list={[gridBase]}>
			<label
				for="contact-message"
				class:list={[labelBase, 'max-w-full md:max-w-none']}
			>
				O que você precisa desenvolver ou automatizar?
			</label>
			<p id="contact-message-error" class:list={[errorBase]} role="alert" aria-live="polite"></p>
			<textarea
				id="contact-message"
				name="message"
				required
				maxlength={messageMaxLength}
				rows="3"
				class:list={[
					fieldBase,
					'max-h-[min(9rem,32svh)] resize-none overflow-y-auto leading-snug md:max-h-none md:leading-normal',
					'col-span-full row-start-2 min-w-0 md:col-span-2 md:row-start-2',
				]}
				placeholder="Descreva a sua ideia ou projeto"
				aria-describedby="contact-message-error"
			></textarea>
		</div>
	</div>
	<div class="flex w-full max-w-full justify-center overflow-x-auto [-webkit-overflow-scrolling:touch] md:overflow-x-visible">
		<div class="inline-flex max-w-full origin-top scale-[0.92] md:scale-100">
			<div class="h-captcha" id="h-captcha-response" data-captcha="true" data-theme="dark" />
		</div>
	</div>
	<Button
		type="submit"
		class="w-full px-4 py-3 text-sm leading-snug md:px-6 md:py-5 md:text-lg md:leading-normal"
	>
		Receber diagnóstico gratuito
	</Button>
	<p id="form-status" class="hidden text-center text-sm text-secondary" role="status" aria-live="polite"></p>
</form>


<script src="https://web3forms.com/client/script.js" async defer></script>
<script>
	import { initContactForm } from './contact-form.client'

	const form = document.getElementById('contact-form')
	if (form instanceof HTMLFormElement) {
		const endpointInput = form.querySelector<HTMLInputElement>('input[name="form_submit_endpoint"]')
		const endpoint = endpointInput?.value?.trim() ?? ''
		initContactForm(form, {
			formSubmitEndpoint: endpoint,
			resetCaptcha: () =>
				(window as Window & { hcaptcha?: { reset?: () => void } }).hcaptcha?.reset?.(),
		})
	}
</script>
