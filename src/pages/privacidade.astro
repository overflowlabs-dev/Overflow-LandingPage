---
import BaseLayout from '../layouts/BaseLayout.astro'
import GrainOverlay from '../components/GrainOverlay.astro'
import PrivacySection from '../components/privacy/PrivacySection.astro'

const title = 'Política de Privacidade | Overflow Labs'
const description =
	'Saiba como a Overflow Labs coleta, usa e protege seus dados pessoais em nosso site, formulário de contato e canais de atendimento.'
---

<BaseLayout title={title} description={description} canonical="https://overflowlabs.com.br/privacidade">
	<GrainOverlay />
	<main class="min-h-screen">
		<nav class="fixed top-0 z-50 min-h-14 w-full border-b border-white/10 bg-neutral-950/95 backdrop-blur-md">
			<div
				class="mx-auto grid min-h-14 w-full max-w-screen-2xl grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-x-2 px-3 py-2 sm:gap-x-3 sm:px-4 md:px-8"
			>
				<a
					href="/"
					class="inline-flex min-w-0 max-w-full items-center gap-1.5 justify-self-start text-xs text-secondary/80 transition-colors hover:text-white sm:gap-2 sm:text-sm"
					aria-label="Voltar para a página inicial"
				>
					<span class="material-symbols-outlined shrink-0 text-base" aria-hidden="true">arrow_back</span>
					<span class="truncate md:whitespace-normal">
						<span class="md:hidden">Voltar</span>
						<span class="hidden md:inline">Voltar para a página inicial</span>
					</span>
				</a>
				<img
					src="/logo.svg"
					alt="Overflow Labs"
					class="h-6 w-auto shrink-0 object-contain sm:h-7"
					width="120"
					height="36"
				/>
				<a
					href="mailto:contato@overflowlabs.com.br"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex min-w-0 max-w-full items-center justify-end gap-1.5 text-xs text-secondary/80 transition-colors hover:text-white sm:gap-2 sm:text-sm"
					aria-label="Enviar e-mail para contato de suporte"
				>
					<span class="hidden text-end sm:inline md:hidden">Suporte</span>
					<span class="hidden text-end md:inline">Contato de Suporte</span>
					<span class="material-symbols-outlined shrink-0 text-base" aria-hidden="true">mail</span>
				</a>
			</div>
		</nav>

		<section class="mx-auto max-w-screen-2xl px-4 pt-28 pb-20 md:px-8">
			<div class="mx-auto max-w-4xl">
				<h1 class="font-headline text-5xl font-bold tracking-tighter text-white md:text-6xl">
					Política de Privacidade
				</h1>
				<div class="mt-4 h-px w-24 bg-primary"></div>

				<div class="mt-14 space-y-12 text-on-surface">
					<PrivacySection />

					<div class="border-t border-outline-variant/30 pt-8">
						<p class="font-label text-xs uppercase tracking-[0.2em] text-secondary/80">
							Última atualização: Abril de 2026
						</p>
					</div>
				</div>
			</div>
		</section>
	</main>
	<footer class="border-t border-white/10 bg-surface-container-low px-4 py-10 md:px-8">
		<div
			class="mx-auto flex max-w-screen-2xl items-center justify-between gap-4 text-center font-body uppercase tracking-widest"
			style="font-size: var(--ols-text-footer)"
		>
			<a href="/" class="inline-flex shrink-0 items-center">
				<img
					src="/logo.svg"
					alt="Overflow Labs"
					width="160"
					height="84"
					class="h-7 w-auto max-w-[min(100%,10rem)] object-contain md:h-8"
				/>
			</a>
			<p class="text-[color:var(--ols-color-link-muted-footer)] w-full">© 2026 OVERFLOW LABS. AUTOMATIZE. INTEGRE. TRANSBORDE.</p>
		</div>
	</footer>
</BaseLayout>
