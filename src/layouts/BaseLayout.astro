---
import '../styles/global.css'
import { getPublicEnv } from '../lib/env-provider.mjs'

interface Props {
	title: string
	description: string
	ogImage?: string
	canonical?: string
}

const {
	title,
	description,
	ogImage = '/og-image.png',
	canonical = Astro.url.href,
} = Astro.props

const site = Astro.site ?? new URL('https://overflowlabs.com.br')
const ogImageAbsoluto = new URL(ogImage, site).href
const logoAbsoluto = new URL('/logo.svg', site).href

const env = getPublicEnv(import.meta.env)
const sameAs = [env.PUBLIC_INSTAGRAM_URL, env.PUBLIC_WHATSAPP_URL].filter(
	(u): u is string => typeof u === 'string' && /^https:\/\//i.test(u.trim()),
)

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	name: 'Overflow Labs',
	url: site.href,
	logo: logoAbsoluto,
	description,
	areaServed: 'BR',
	address: {
		'@type': 'PostalAddress',
    	addressCountry: 'BR',
    	addressLocality: 'Ponta Grossa',
    	addressRegion: 'PR'
	},
	sameAs,
}

const jsonLdScript = JSON.stringify(jsonLd).replace(/</g, '\\u003c')
---

<!doctype html>
<html class="dark" lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageAbsoluto} />
		<meta property="og:image:width" content="1080" />
		<meta property="og:image:height" content="600" />
		<meta property="og:locale" content="pt_BR" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageAbsoluto} />

		<link rel="icon" type="image/svg+xml" href="/logo.svg" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;700&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,200,0,0&display=swap"
			rel="stylesheet"
		/>

		<script type="application/ld+json" set:html={jsonLdScript} />
	</head>
	<body class="bg-background text-on-surface font-body overflow-x-hidden antialiased">
		<slot />
	</body>
</html>
